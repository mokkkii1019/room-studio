# Room Studio 設定ファイルのサンプル。
# このファイルを「.env」という名前でコピーし、値を入れてください（server.py が読み込みます）。
#   Windows: copy .env.example .env
#   Mac/Linux: cp .env.example .env
# 設定後は server.py を再起動（run.bat / run.sh / python server.py）。

# 楽天 商品検索API（ART OF BLACK など楽天店からの収集に必須）。https://webservice.rakuten.co.jp/ の
# 「アプリ一覧」に表示される値をそのままコピー（新仕様では APP_ID＝UUID と ACCESS_KEY の両方が必要）。
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=

# 楽天アフィリエイトID（任意）。設定すると収集商品の「購入」リンクがアフィリエイトURLになります。
RAKUTEN_AFFILIATE_ID=

# 任意。楽天アプリの「許可されたWebサイト」に合わせる（既定: https://github.com/）。
# 別ドメインを許可サイトに登録した場合のみ変更。Origin は自動でこのURLのドメインから生成。
RAKUTEN_REFERER=https://github.com/

# ---- 収集プロバイダの切替（フェーズ0） ----
# APP_MODE: public = 公開用。クローラ(IKEA/Shopify)は import すらされず、要求しても 403。
#           private = 自分用。クローラを選べる（自己ホスト/私的利用のみ）。
# COLLECT_PROVIDER: official = 楽天など正規APIのみ / crawler = クローラ（private時のみ有効）。
# 公開デプロイ(Vercel)は既定(public/official)のまま。ローカルで IKEA/Shopify を使うなら下記を有効化:
#   APP_MODE=private
#   COLLECT_PROVIDER=crawler
APP_MODE=public
COLLECT_PROVIDER=official
