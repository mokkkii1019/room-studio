# Keep the serverless build lean and safe.
# CRITICAL: exclude the heavy local requirements + dev server so Vercel does NOT
# try to install torch/PIL/etc for the (stdlib-only) /api functions.
server.py
tools/
# CRITICAL: never ship the private-use crawler to the public deployment.
# (Runtime is also guarded: APP_MODE=public refuses to import it — see get_provider.)
api/_provider_crawler.py
requirements-local.txt
.env
.env.example
setup.bat
setup.sh
run.bat
run.sh
*.md
.gitignore
.gitattributes
__pycache__/
api/__pycache__/
.venv/
venv/
node_modules/
