# Keep the serverless build lean and safe.
# CRITICAL: exclude the heavy local requirements + dev server so Vercel does NOT
# try to install torch/PIL/etc for the (stdlib-only) /api functions.
server.py
tools/
# NOTE (private-web branch): the crawler IS shipped here on purpose. This branch backs a
# SEPARATE, access-gated private deployment (APP_MODE=private + COLLECT_PROVIDER=crawler +
# ACCESS_TOKEN). The PUBLIC deployment must be built from `main`, where this file is excluded.
requirements-local.txt
.env
.env.example
setup.bat
setup.sh
run.bat
run.sh
*.md
.gitignore
.gitattributes
__pycache__/
api/__pycache__/
.venv/
venv/
node_modules/
