# Shell scripts must use LF so they run on macOS/Linux (CRLF breaks the shebang).
*.sh text eol=lf
# Windows batch files use CRLF.
*.bat text eol=crlf
# The single-page app is authored with LF; a stray CRLF rewrite makes the whole file
# show as changed and hides the real diff.
room-studio.html text eol=lf
